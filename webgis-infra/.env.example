# ============================================================
# .env.example — Variáveis de ambiente WebGIS
# Copie para .env e configure: cp .env.example .env
# NUNCA commite o .env no git!
# ============================================================

# ── BANCO DE DADOS ─────────────────────────────────────────
POSTGRES_DB=webgis
POSTGRES_USER=webgis
POSTGRES_PASSWORD=TROQUE_ESTA_SENHA_FORTE_AQUI    # Mínimo 20 caracteres

# ── DOMÍNIO E SSL ─────────────────────────────────────────
DOMAIN=seusite.com.br
LETSENCRYPT_EMAIL=seu@email.com

# ── APLICAÇÃO ─────────────────────────────────────────────
# Imagem Docker da sua aplicação (GHCR ou Docker Hub)
APP_IMAGE=ghcr.io/seu-usuario/seu-repo/webgis-app:latest

# ── MONITORAMENTO ─────────────────────────────────────────
MONITOR_USER=admin
# Hash bcrypt da senha (gere com: htpasswd -nbB admin "sua_senha")
MONITOR_PASS_HASH=$2a$14$exemplo_hash_aqui

# Opcional: token do Netdata Cloud (monitoramento remoto gratuito)
NETDATA_CLAIM_TOKEN=

# ── BACKUP — BACKBLAZE B2 (10GB gratuito) ─────────────────
# Crie uma conta em backblaze.com e gere Application Key
B2_BUCKET=webgis-backups
RCLONE_REMOTE=backblaze
BACKUP_RETENTION_DAYS=7

# ── ALERTAS (opcional) ────────────────────────────────────
# Webhook para alertas de falha no backup (Slack/Discord/Telegram)
ALERT_WEBHOOK_URL=

# ── CLOUDFLARE (opcional — para purge de cache via API) ───
CF_ZONE_ID=
CF_API_TOKEN=

# ── CUSTO ESTIMADO COM ESTA CONFIG (Vultr São Paulo) ──────
# VPS 4vCPU/8GB:        ~R$126/mês
# Cloudflare CDN:        R$0    (gratuito)
# GitHub Actions CI/CD:  R$0    (gratuito, <2000 min/mês)
# Backblaze B2 backup:   R$0    (gratuito até 10GB)
# Let's Encrypt SSL:     R$0    (gratuito via Caddy)
# Uptime Kuma:           R$0    (self-hosted)
# Netdata:               R$0    (self-hosted)
# ────────────────────────────────────────────────────────
# TOTAL:                ~R$126/mês para WebGIS com 200k geom
